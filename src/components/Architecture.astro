---
const stages = [
  { name: "RT", temp: "300 K", color: "#ef4444" },
  { name: "50K", temp: "50 K", color: "#f97316" },
  { name: "4K", temp: "4 K", color: "#eab308" },
  { name: "Still", temp: "~800 mK", color: "#22c55e" },
  { name: "MXC", temp: "~10 mK", color: "#3b82f6" },
  { name: "CP", temp: "~10 mK", color: "#8b5cf6" },
];

const components = [
  { name: "Attenuator", field: "value_dB", example: "10 dB" },
  { name: "Filter", field: "filter_type", example: "Lowpass" },
  { name: "Isolator", field: "-", example: "ISO" },
  { name: "Amplifier", field: "gain_dB", example: "+40 dB" },
];
---

<section class="section architecture-section">
  <div class="container">
    <h2 class="section-title scroll-reveal">Data Model</h2>
    <p class="section-subtitle scroll-reveal">
      A standardized format for describing RF/microwave wiring inside dilution
      refrigerators.
    </p>
    <div class="architecture-grid scroll-stagger">
      <div class="arch-card">
        <h3 class="arch-card-title">Temperature Stages</h3>
        <div class="stages-list">
          {
            stages.map((stage) => (
              <div class="stage-item">
                <span class="stage-dot" style={`background: ${stage.color}`} />
                <span class="stage-name">{stage.name}</span>
                <span class="stage-temp">{stage.temp}</span>
              </div>
            ))
          }
        </div>
      </div>
      <div class="arch-card">
        <h3 class="arch-card-title">Component Types</h3>
        <table class="components-table">
          <thead>
            <tr>
              <th>Component</th>
              <th>Key Field</th>
              <th>Label</th>
            </tr>
          </thead>
          <tbody>
            {
              components.map((c) => (
                <tr>
                  <td class="comp-name">{c.name}</td>
                  <td>
                    <code>{c.field}</code>
                  </td>
                  <td>
                    <code>{c.example}</code>
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
      <div class="arch-card">
        <h3 class="arch-card-title">Line Types</h3>
        <div class="lines-list">
          <div class="line-item">
            <span class="line-indicator" style="background: var(--color-primary);"
            ></span>
            <div>
              <strong>Control</strong>
              <p>Drive signals to qubits</p>
            </div>
          </div>
          <div class="line-item">
            <span class="line-indicator" style="background: var(--color-success);"
            ></span>
            <div>
              <strong>Readout Send</strong>
              <p>Measurement stimulus</p>
            </div>
          </div>
          <div class="line-item">
            <span class="line-indicator" style="background: var(--color-accent);"
            ></span>
            <div>
              <strong>Readout Return</strong>
              <p>Amplified return signal</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .architecture-section {
    background: var(--color-bg-secondary);
  }

  .architecture-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .arch-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.5rem;
  }

  .arch-card-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .stages-list {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .stage-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.875rem;
  }

  .stage-dot {
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .stage-name {
    font-weight: 600;
    font-family: var(--font-mono);
    min-width: 3rem;
  }

  .stage-temp {
    color: var(--color-text-muted);
  }

  .components-table {
    width: 100%;
    font-size: 0.85rem;
    border-collapse: collapse;
  }

  .components-table th {
    text-align: left;
    font-weight: 500;
    color: var(--color-text-muted);
    padding-bottom: 0.5rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .components-table td {
    padding: 0.4rem 0;
    border-top: 1px solid var(--color-border);
  }

  .comp-name {
    font-weight: 500;
  }

  .components-table code {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-warning);
  }

  .lines-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .line-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .line-indicator {
    width: 0.25rem;
    height: 2.5rem;
    border-radius: 0.125rem;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  .line-item strong {
    display: block;
    font-size: 0.875rem;
    margin-bottom: 0.125rem;
  }

  .line-item p {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
</style>
