---
const repos = [
  {
    name: "spec",
    description:
      "Formal specification and JSON Schema definitions for the YAML wiring format. Defines stages, component types, and line types.",
    tags: ["JSON Schema", "Specification"],
    href: "https://github.com/cryowire/spec",
    docsHref: "https://cryowire.github.io/spec/",
  },
  {
    name: "cryowire",
    description:
      "Python library and CLI providing data models, validation, diagram generation, programmatic building, and a terminal interface for wiring configurations.",
    tags: ["Python", "CLI", "Pydantic", "matplotlib"],
    href: "https://github.com/cryowire/cryowire",
    docsHref: "https://cryowire.github.io/core/",
  },
  {
    name: "app",
    description:
      "Web application with FastAPI backend and Next.js frontend for browsing, editing, and managing wiring configs.",
    tags: ["FastAPI", "Next.js", "Docker"],
    href: "https://github.com/cryowire/app",
  },
  {
    name: "viewer",
    description:
      "Read-only browser for cooldown.yaml files. Drop a file to instantly view cooldown metadata, wiring summary tables, and line details.",
    tags: ["React", "Vite", "TypeScript"],
    href: "https://github.com/cryowire/viewer",
    docsHref: "https://cryowire.github.io/viewer/",
    liveHref: "https://cryowire.github.io/viewer/",
  },
  {
    name: "template",
    description:
      "GitHub template repository for creating dilution refrigerator wiring data repositories with recommended structure.",
    tags: ["Template", "YAML"],
    href: "https://github.com/cryowire/template",
  },
  {
    name: "vscode-extension",
    description:
      "VS Code extension that previews cooldown.yaml files as interactive wiring diagrams in a side panel with auto-reload.",
    tags: ["VS Code", "TypeScript"],
    href: "https://github.com/cryowire/vscode-extension",
  },
  {
    name: "chrome-extension",
    description:
      "Chrome extension that detects cooldown.yaml on GitHub and opens the cryowire viewer with one click.",
    tags: ["Chrome", "React", "TypeScript"],
    href: "https://github.com/cryowire/chrome-extension",
  },
  {
    name: "action",
    description:
      "GitHub Action that auto-discovers cooldown directories and runs validate + build in CI on every push and pull request.",
    tags: ["GitHub Actions", "CI/CD"],
    href: "https://github.com/cryowire/action",
  },
];
---

<section id="ecosystem" class="section ecosystem-section">
  <div class="container">
    <h2 class="section-title scroll-reveal">Ecosystem</h2>
    <p class="section-subtitle scroll-reveal">
      A modular, well-separated architecture across eight repositories.
    </p>
    <div class="ecosystem-grid scroll-stagger">
      {
        repos.map((repo) => (
          <div class="repo-card">
            <div class="repo-header">
              <h3 class="repo-name">
                <a href={repo.href} target="_blank" rel="noopener noreferrer">
                  cryowire/<span class="repo-name-highlight">{repo.name}</span>
                </a>
              </h3>
              {repo.docsHref && (
                <a
                  href={repo.docsHref}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="repo-docs-link"
                >
                  Docs
                </a>
              )}
            </div>
            <p class="repo-description">{repo.description}</p>
            {repo.liveHref && (
              <a
                href={repo.liveHref}
                target="_blank"
                rel="noopener noreferrer"
                class="repo-live-link"
              >
                Try it live &rarr;
              </a>
            )}
            <div class="repo-tags">
              {repo.tags.map((tag) => (
                <span class="repo-tag">{tag}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .ecosystem-section {
    background: var(--color-bg-secondary);
  }

  .ecosystem-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 1.25rem;
  }

  .repo-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s;
  }

  .repo-card:hover {
    border-color: rgba(129, 140, 248, 0.3);
  }

  .repo-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .repo-name {
    font-size: 1rem;
    font-weight: 600;
    font-family: var(--font-mono);
  }

  .repo-name a {
    color: var(--color-text-muted);
  }

  .repo-name a:hover {
    color: var(--color-text);
  }

  .repo-name-highlight {
    color: var(--color-primary);
  }

  .repo-docs-link {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-accent);
    padding: 0.25rem 0.75rem;
    border: 1px solid rgba(129, 140, 248, 0.3);
    border-radius: 9999px;
  }

  .repo-docs-link:hover {
    background: rgba(129, 140, 248, 0.1);
    color: var(--color-accent);
  }

  .repo-description {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    flex: 1;
    margin-bottom: 1rem;
  }

  .repo-live-link {
    display: inline-flex;
    align-items: center;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-primary);
    padding: 0.5rem 1rem;
    background: rgba(56, 189, 248, 0.08);
    border: 1px solid rgba(56, 189, 248, 0.25);
    border-radius: 0.375rem;
    margin-bottom: 1rem;
    transition: all 0.2s;
    width: fit-content;
  }

  .repo-live-link:hover {
    background: rgba(56, 189, 248, 0.15);
    border-color: rgba(56, 189, 248, 0.5);
    color: var(--color-primary);
  }

  .repo-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .repo-tag {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-text-muted);
    padding: 0.2rem 0.6rem;
    background: var(--color-bg-card);
    border-radius: 0.25rem;
  }
</style>
