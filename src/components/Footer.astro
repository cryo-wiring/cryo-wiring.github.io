---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="footer-logo">&#10052; cryo-wiring</span>
      <p class="footer-tagline">
        Open-source tools for dilution refrigerator wiring management.
      </p>
    </div>
    <div class="footer-links">
      <div class="footer-column">
        <h4>Repositories</h4>
        <a href="https://github.com/cryo-wiring/spec" target="_blank" rel="noopener noreferrer">spec</a>
        <a href="https://github.com/cryo-wiring/core" target="_blank" rel="noopener noreferrer">core</a>
        <a href="https://github.com/cryo-wiring/cli" target="_blank" rel="noopener noreferrer">cli</a>
        <a href="https://github.com/cryo-wiring/app" target="_blank" rel="noopener noreferrer">app</a>
        <a href="https://github.com/cryo-wiring/viewer" target="_blank" rel="noopener noreferrer">viewer</a>
      </div>
      <div class="footer-column">
        <h4>Documentation</h4>
        <a href="https://cryo-wiring.github.io/spec/">Specification</a>
        <a href="https://cryo-wiring.github.io/core/">Core Library</a>
        <a href="https://cryo-wiring.github.io/viewer/">Viewer</a>
      </div>
    </div>
  </div>
  <div class="container footer-bottom">
    <p>MIT License &middot; cryo-wiring</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 3rem 0 0;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .footer-brand {
    max-width: 280px;
  }

  .footer-logo {
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--color-text);
  }

  .footer-tagline {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
    line-height: 1.6;
  }

  .footer-links {
    display: flex;
    gap: 3rem;
  }

  .footer-column {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-column h4 {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: 0.25rem;
  }

  .footer-column a {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .footer-column a:hover {
    color: var(--color-text);
  }

  .footer-bottom {
    margin-top: 2rem;
    padding: 1.25rem 0;
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .footer-bottom p {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
</style>
